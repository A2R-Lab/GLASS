build/
results/*.json
# Per-host autotune outputs. The autotune script writes
# bench/tuning/<hostname>.cuh + a results .md alongside; both are local
# artifacts consumed via -DGLASS_TUNING_TABLE_LOCAL='"path/to/file"'.
tuning/*.cuh
tuning/*_results.md
__pycache__/
# Raw timing captures written by bench/tune.py / the harnesses (large, per-run).
# The curated *_RESULTS.md summaries and regenerated tables ARE tracked.
mega_sweep_*.txt
reduced_sweep_*.txt
warp_block_sweep_*.txt
*.log
